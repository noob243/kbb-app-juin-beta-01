rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Handled helpers
    function isSignedIn() {
      return true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isStringWithSize(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    function isNumber(val) {
      return val is int || val is float;
    }

    // Helper to validate Client schema
    function isValidClient(data) {
      return data.keys().hasAll(['id', 'name', 'contact'])
        && isNumber(data.id)
        && isStringWithSize(data.name, 100)
        && isStringWithSize(data.contact, 100);
    }

    // Helper to validate Case schema
    function isValidCase(data) {
      return data.keys().hasAll(['id', 'name', 'client', 'status'])
        && isStringWithSize(data.id, 50)
        && isStringWithSize(data.name, 150)
        && isStringWithSize(data.client, 150)
        && (data.status == 'Nouveau' || data.status == 'En cours' || data.status == 'En attente' || data.status == 'Clôturé');
    }

    // Helper to validate Event schema
    function isValidEvent(data) {
      return data.keys().hasAll(['id', 'name', 'type', 'date', 'lieu'])
        && isStringWithSize(data.id, 50)
        && isStringWithSize(data.name, 150)
        && isStringWithSize(data.type, 50)
        && isStringWithSize(data.date, 50)
        && isStringWithSize(data.lieu, 150);
    }

    // Helper to validate Avocat schema
    function isValidAvocat(data) {
      return data.keys().hasAll(['id', 'fullName', 'firstOathDate', 'onaNumber', 'cabinetStatus', 'serviceStatus', 'phone'])
        && isStringWithSize(data.id, 50)
        && isStringWithSize(data.fullName, 150)
        && isStringWithSize(data.firstOathDate, 50)
        && isStringWithSize(data.onaNumber, 50)
        && isStringWithSize(data.cabinetStatus, 50)
        && isStringWithSize(data.serviceStatus, 50)
        && isStringWithSize(data.phone, 50);
    }

    // Helper to validate Task schema
    function isValidTask(data) {
      return data.keys().hasAll(['id', 'name', 'caseId', 'lawyer', 'dueDate', 'status'])
        && isNumber(data.id)
        && isStringWithSize(data.name, 200)
        && isStringWithSize(data.caseId, 50)
        && isStringWithSize(data.lawyer, 150)
        && isStringWithSize(data.dueDate, 50)
        && (data.status == 'Effectué' || data.status == 'Non effectué' || data.status == 'Effectué à moitié');
    }

    // Helper to validate Invoice schema
    function isValidInvoice(data) {
      return data.keys().hasAll(['id', 'caseId', 'dueDate', 'totalAmount', 'paidAmount', 'status'])
        && isStringWithSize(data.id, 50)
        && isStringWithSize(data.caseId, 50)
        && isStringWithSize(data.dueDate, 50)
        && isNumber(data.totalAmount)
        && isNumber(data.paidAmount)
        && (data.status == 'Réglée' || data.status == 'Non réglée' || data.status == 'En cours');
    }

    // Helper to validate Personnel schema
    function isValidPersonnel(data) {
      return data.keys().hasAll(['id', 'fullName', 'role', 'email', 'phone', 'serviceStartDate', 'serviceStatus', 'salary'])
        && isStringWithSize(data.id, 50)
        && isStringWithSize(data.fullName, 150)
        && isStringWithSize(data.role, 100)
        && isStringWithSize(data.email, 100)
        && isStringWithSize(data.phone, 50)
        && isStringWithSize(data.serviceStartDate, 50)
        && isStringWithSize(data.serviceStatus, 50)
        && isNumber(data.salary);
    }

    // Helper to validate Fournisseur schema
    function isValidFournisseur(data) {
      return data.keys().hasAll(['id', 'nomComplet', 'naturePrestation', 'typeFacturation', 'montant'])
        && isStringWithSize(data.id, 50)
        && isStringWithSize(data.nomComplet, 150)
        && isStringWithSize(data.naturePrestation, 50)
        && isStringWithSize(data.typeFacturation, 50)
        && isNumber(data.montant);
    }

    // Clients rules
    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidClient(request.resource.data);
      allow update: if isSignedIn() && isValidClient(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Cases rules
    match /cases/{caseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidCase(request.resource.data);
      allow update: if isSignedIn() && isValidCase(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Events rules
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidEvent(request.resource.data);
      allow update: if isSignedIn() && isValidEvent(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Avocats rules
    match /avocats/{avocatId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidAvocat(request.resource.data);
      allow update: if isSignedIn() && isValidAvocat(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Tasks rules
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidTask(request.resource.data);
      allow update: if isSignedIn() && isValidTask(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Invoices rules
    match /invoices/{invoiceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidInvoice(request.resource.data);
      allow update: if isSignedIn() && isValidInvoice(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Personnels rules
    match /personnels/{personnelId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPersonnel(request.resource.data);
      allow update: if isSignedIn() && isValidPersonnel(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Fournisseurs rules
    match /fournisseurs/{fournisseurId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidFournisseur(request.resource.data);
      allow update: if isSignedIn() && isValidFournisseur(request.resource.data);
      allow delete: if isSignedIn();
    }
  }
}
